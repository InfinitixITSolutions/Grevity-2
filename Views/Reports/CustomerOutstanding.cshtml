@model IEnumerable<Grevity.Models.Entities.Customer>

@{
    ViewData["Title"] = "Ledger: Customer Outstandings";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="h3 mb-1">Customer Outstanding Ledger</h2>
        <p class="text-muted">Consolidated balances and credit status for all clients.</p>
    </div>
    <div class="col-md-6 text-md-end no-print">
        <button class="btn btn-primary rounded-pill px-4 me-2" onclick="window.print()">
            <span class="material-symbols-outlined align-middle me-1">print</span> Print Statement
        </button>
        <a asp-controller="Reports" asp-action="Index" class="btn btn-light rounded-pill px-4">
            <span class="material-symbols-outlined align-middle me-1">arrow_back</span> Back
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden mb-5">
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="outstandingTable">
            <thead>
                <tr>
                    <th class="ps-4">Customer Entity</th>
                    <th>Contact</th>
                    <th class="text-end">Opening Bal.</th>
                    <th class="text-end pe-4">Current Outstanding</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold fs-6">@item.Name</div>
                            <div class="text-muted x-small text-uppercase ls-1">Client</div>
                        </td>
                        <td>
                            <div class="small">@item.Mobile</div>
                        </td>
                        <td class="text-end text-muted">@item.OpeningBalance.ToString("C")</td>
                        <td class="text-end pe-4 fw-bold text-danger">@item.CurrentBalance.ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot class="bg-light border-top border-2 fw-bold">
                <tr>
                    <td colspan="3" class="ps-4 py-3">CUMULATIVE RECEIVABLES</td>
                    <td class="text-end pe-4 text-danger fs-5">@Model.Sum(c => c.CurrentBalance).ToString("C")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<style>
    .ls-1 { letter-spacing: 0.05em; }
    @@media print {
        .no-print { display: none !important; }
        .card { border: 1px solid #dee2e6 !important; box-shadow: none !important; }
    }
</style>
