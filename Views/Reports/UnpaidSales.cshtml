@model IEnumerable<Grevity.Models.Entities.Invoice>

@{
    ViewData["Title"] = "Outstandings: Unpaid Sales";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="h3 mb-1">Unpaid Sales Report</h2>
        <p class="text-muted">Tracking pending collections and overdue invoices.</p>
    </div>
    <div class="col-md-6 text-md-end no-print">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-light rounded-pill px-4">
            <span class="material-symbols-outlined align-middle me-1">arrow_back</span> Back to Analytics
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm bg-success bg-opacity-10 text-success p-5 text-center rounded-4">
        <span class="material-symbols-outlined display-1 mb-3">cloud_done</span>
        <h2 class="fw-bold">All clear!</h2>
        <p class="lead mb-0">All sales invoices have been fully settled. Great job on collections!</p>
    </div>
}
else
{
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-danger text-white p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 small fw-bold text-uppercase ls-1 mb-1">Total Outstanding</h6>
                        <h2 class="mb-0 fw-bold">@Model.Sum(i => i.RemainingAmount).ToString("C")</h2>
                    </div>
                    <span class="material-symbols-outlined opacity-50" style="font-size: 3rem">trending_up</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-white p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase ls-1 mb-1">Total Received</h6>
                        <h2 class="mb-0 fw-bold text-success">@Model.Sum(i => i.PaidAmount).ToString("C")</h2>
                    </div>
                    <span class="material-symbols-outlined text-success opacity-50" style="font-size: 3rem">payments</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-white p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase ls-1 mb-1">Pending Count</h6>
                        <h2 class="mb-0 fw-bold text-warning">@Model.Count() Invoices</h2>
                    </div>
                    <span class="material-symbols-outlined text-warning opacity-50" style="font-size: 3rem">pending_actions</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Document</th>
                        <th>Customer</th>
                        <th class="text-end">Grand Total</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Remaining</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-4 no-print">Resolve</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <a asp-controller="Invoice" asp-action="Details" asp-route-id="@invoice.Id" class="text-decoration-none">
                                    <div class="fw-bold">@invoice.InvoiceNumber</div>
                                    <div class="text-muted x-small">@invoice.InvoiceDate.ToString("dd MMM yyyy")</div>
                                </a>
                            </td>
                            <td>
                                <div class="fw-bold fs-6">@invoice.Customer?.Name</div>
                            </td>
                            <td class="text-end">@invoice.GrandTotal.ToString("C")</td>
                            <td class="text-end text-success">@invoice.PaidAmount.ToString("C")</td>
                            <td class="text-end text-danger fw-bold">@invoice.RemainingAmount.ToString("C")</td>
                            <td class="text-center">
                                <span class="badge @(invoice.PaymentStatus == "Paid" ? "bg-success" : invoice.PaymentStatus == "Partial Paid" ? "bg-warning text-dark" : "bg-danger") bg-opacity-10 text-@(invoice.PaymentStatus == "Paid" ? "success" : invoice.PaymentStatus == "Partial Paid" ? "warning" : "danger")">
                                    @invoice.PaymentStatus
                                </span>
                            </td>
                            <td class="text-center pe-4 no-print">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-light btn-sm text-info" title="View Details">
                                        <span class="material-symbols-outlined" style="font-size: 1.2rem">visibility</span>
                                    </a>
                                    <a asp-controller="Invoice" asp-action="AddPayment" asp-route-id="@invoice.Id" class="btn btn-purple-light btn-sm text-primary" title="Record Payment">
                                        <span class="material-symbols-outlined" style="font-size: 1.2rem">add_card</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-light border-top border-2 fw-bold">
                    <tr>
                        <td colspan="2" class="ps-4 py-3">GRAND TOTALS</td>
                        <td class="text-end">@Model.Sum(i => i.GrandTotal).ToString("C")</td>
                        <td class="text-end text-success">@Model.Sum(i => i.PaidAmount).ToString("C")</td>
                        <td class="text-end text-danger">@Model.Sum(i => i.RemainingAmount).ToString("C")</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

<style>
    .ls-1 { letter-spacing: 0.05em; }
    @@media print {
        .no-print { display: none !important; }
        .card { border: 1px solid #dee2e6 !important; box-shadow: none !important; }
    }
</style>
