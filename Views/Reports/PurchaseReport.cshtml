@model IEnumerable<Grevity.Models.Entities.Invoice>

@{
    ViewData["Title"] = "Purchase Analysis Report";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="h3 mb-1">Purchase Analysis</h2>
        <p class="text-muted">Detailed breakdown of procurement across dates.</p>
    </div>
</div>

<div class="card border-0 mb-4 bg-light shadow-none">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-uppercase text-muted ls-1">From Date</label>
                <input type="date" name="fromDate" class="form-control border-0 shadow-sm rounded-3" value="@(ViewBag.FromDate is DateTime fd ? fd.ToString("yyyy-MM-dd") : "")">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-uppercase text-muted ls-1">To Date</label>
                <input type="date" name="toDate" class="form-control border-0 shadow-sm rounded-3" value="@(ViewBag.ToDate is DateTime td ? td.ToString("yyyy-MM-dd") : "")">
            </div>
            <div class="col-md-6 text-md-end">
                <button type="submit" class="btn btn-primary px-4 rounded-pill">
                    <span class="material-symbols-outlined align-middle me-1">filter_list</span> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Bill #</th>
                    <th>Date</th>
                    <th>Supplier</th>
                    <th class="text-end">Tax</th>
                    <th class="text-end">Paid</th>
                    <th class="text-end">Balance</th>
                    <th class="text-end pe-4">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <span class="fw-bold">@item.InvoiceNumber</span>
                        </td>
                        <td>@item.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td>@item.Supplier?.Name</td>
                        <td class="text-end text-muted">@item.TaxAmount.ToString("C")</td>
                        <td class="text-end text-success fw-bold">@item.PaidAmount.ToString("C")</td>
                        <td class="text-end text-danger">@((item.GrandTotal - item.PaidAmount).ToString("C"))</td>
                        <td class="text-end fw-bold pe-4">@item.GrandTotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot class="bg-light border-top border-2">
                <tr class="fw-bold">
                    <td colspan="3" class="ps-4 py-3">GRAND TOTAL</td>
                    <td class="text-end">@Model.Sum(x => x.TaxAmount).ToString("C")</td>
                    <td class="text-end text-success">@Model.Sum(x => x.PaidAmount).ToString("C")</td>
                    <td class="text-end text-danger">@Model.Sum(x => x.GrandTotal - x.PaidAmount).ToString("C")</td>
                    <td class="text-end pe-4">@Model.Sum(x => x.GrandTotal).ToString("C")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<style>
    .ls-1 { letter-spacing: 0.05em; }
</style>
