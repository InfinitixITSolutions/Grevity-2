@model Grevity.Models.Entities.BusinessSetting

@{
    ViewData["Title"] = "Business Profile Settings";
    var allCompanies = ViewBag.AllCompanies as IEnumerable<Grevity.Models.Entities.BusinessSetting>;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="h3 mb-1">Company Configuration</h2>
        <p class="text-muted">Manage your business profile, identity, and tax preferences.</p>
    </div>
    <div class="col-md-6 text-md-end">
        <div class="dropdown d-inline-block company-switcher-dropdown">
            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle company-pill shadow-sm" id="companyDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="material-symbols-outlined align-middle me-1 text-primary">business</span>
                <span class="fw-bold">@(Model != null && Model.Id > 0 ? Model.CompanyName : "Select Company")</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2 rounded-4" aria-labelledby="companyDropdown">
                <li class="px-3 py-2 border-bottom mb-1">
                    <span class="text-muted small fw-bold text-uppercase ls-1">Switch Entity</span>
                </li>
                @if (allCompanies != null)
                {
                    foreach (var company in allCompanies)
                    {
                        <li><a class="dropdown-item rounded-2 py-2 d-flex align-items-center @(Model?.Id == company.Id ? "active" : "")" asp-action="Index" asp-route-id="@company.Id">
                            <span class="material-symbols-outlined me-2" style="font-size: 1.1rem">@(Model?.Id == company.Id ? "check_circle" : "business")</span>
                            @company.CompanyName
                        </a></li>
                    }
                }
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-success rounded-2 py-2 fw-bold d-flex align-items-center" asp-action="Index" asp-route-id="0">
                    <span class="material-symbols-outlined align-middle me-2">add_circle</span> New Registration
                </a></li>
                <li><a class="dropdown-item text-primary rounded-2 py-2 d-flex align-items-center" asp-action="List">
                    <span class="material-symbols-outlined align-middle me-2">list</span> All Entities
                </a></li>
            </ul>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-4 d-flex align-items-center mb-4">
        <span class="material-symbols-outlined me-3">check_circle</span>
        @TempData["Success"]
    </div>
}

@if (Model != null)
{
    <form asp-action="Index" method="post" enctype="multipart/form-data" hx-boost="false">
        <div asp-validation-summary="All" class="text-danger mb-3 small fw-bold"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="UpdatedAt" />
        <input type="hidden" asp-for="LogoPath" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center mb-4">
                        <span class="material-symbols-outlined text-primary me-2">info</span>
                        <h5 class="mb-0 fw-bold">Basic Identity</h5>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="CompanyName" class="form-label small fw-bold text-muted text-uppercase ls-1">Company Name *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><span class="material-symbols-outlined fs-5">corporate_fare</span></span>
                            <input asp-for="CompanyName" class="form-control bg-light border-start-0 ps-0" required placeholder="Enter firm name" />
                        </div>
                        <span asp-validation-for="CompanyName" class="text-danger small"></span>
                    </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase ls-1">Business Email</label>
                                <input asp-for="Email" class="form-control bg-light" placeholder="contact@company.com" />
                                <span asp-validation-for="Email" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label small fw-bold text-muted text-uppercase ls-1">Landline #</label>
                                <input asp-for="Phone" class="form-control bg-light" placeholder="+91 ..." />
                                <span asp-validation-for="Phone" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Mobile" class="form-label small fw-bold text-muted text-uppercase ls-1">Mobile #</label>
                                <input asp-for="Mobile" class="form-control bg-light" placeholder="+91 ..." />
                                <span asp-validation-for="Mobile" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GSTIN" class="form-label small fw-bold text-muted text-uppercase ls-1">GSTIN / TAX ID</label>
                                <input asp-for="GSTIN" class="form-control bg-light fw-bold" placeholder="GST Number" />
                                <span asp-validation-for="GSTIN" class="text-danger x-small"></span>
                            </div>
                        </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 text-center">
                    <div class="d-flex align-items-center mb-4 justify-content-center">
                        <span class="material-symbols-outlined text-primary me-2">image</span>
                        <h5 class="mb-0 fw-bold">Brand Identity</h5>
                    </div>
                    
                    <div class="mb-4 position-relative d-inline-block mx-auto">
                        <div class="rounded-4 bg-light d-flex align-items-center justify-content-center overflow-hidden border" style="width: 160px; height: 160px;">
                            @if (!string.IsNullOrEmpty(Model.LogoPath))
                            {
                                <img src="@Model.LogoPath" alt="Logo" class="img-fluid p-2" />
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <span class="material-symbols-outlined display-3 mb-1">domain</span>
                                    <div class="small">No Logo</div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="btn btn-purple-light btn-sm rounded-pill px-4 cursor-pointer">
                            <span class="material-symbols-outlined align-middle me-1">upload</span> Choose Logo
                            <input type="file" name="logo" class="d-none" accept="image/*" />
                        </label>
                    </div>
                    <p class="text-muted x-small mt-2">Recommended: Square PNG/JPG (Max 2MB)</p>
                </div>
            </div>

            <div class="col-md-12">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="d-flex align-items-center mb-4">
                        <span class="material-symbols-outlined text-primary me-2">location_on</span>
                        <h5 class="mb-0 fw-bold">Address & Region</h5>
                    </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Address" class="form-label small fw-bold text-muted text-uppercase ls-1">Street Address</label>
                                <textarea asp-for="Address" class="form-control bg-light" rows="2" placeholder="Building, Street, Area..."></textarea>
                                <span asp-validation-for="Address" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="City" class="form-label small fw-bold text-muted text-uppercase ls-1">City</label>
                                <input asp-for="City" class="form-control bg-light" />
                                <span asp-validation-for="City" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="State" class="form-label small fw-bold text-muted text-uppercase ls-1">State / Province</label>
                                <input asp-for="State" class="form-control bg-light" />
                                <span asp-validation-for="State" class="text-danger x-small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Country" class="form-label small fw-bold text-muted text-uppercase ls-1">Country</label>
                                <input asp-for="Country" class="form-control bg-light" />
                                <span asp-validation-for="Country" class="text-danger x-small"></span>
                            </div>
                        </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <div class="d-flex align-items-center mb-4">
                        <span class="material-symbols-outlined text-primary me-2">tune</span>
                        <h5 class="mb-0 fw-bold">System Preferences</h5>
                    </div>

                    <div class="row g-4 align-items-end">
                        <div class="col-md-4">
                            <div class="p-3 rounded-4 bg-light border border-dashed text-center h-100">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" asp-for="IsGSTEnabled" id="gstToggle">
                                    <label class="form-check-label fw-bold" for="gstToggle">Enable GST Billing</label>
                                </div>
                                <p class="text-muted x-small mb-0 mt-2">Automatic tax calculations on documents</p>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DefaultGSTPercentage" class="form-label small fw-bold text-muted text-uppercase ls-1">Default GST Rate (%)</label>
                            <div class="input-group">
                                <input asp-for="DefaultGSTPercentage" class="form-control bg-light" placeholder="18" />
                                <span class="input-group-text bg-light border-start-0">%</span>
                            </div>
                            <span asp-validation-for="DefaultGSTPercentage" class="text-danger x-small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CurrentFinancialYear" class="form-label small fw-bold text-muted text-uppercase ls-1">Active Financial Year</label>
                            <select asp-for="CurrentFinancialYear" class="form-select bg-light">
                                <option value="2023-2024">2023-2024</option>
                                <option value="2024-2025">2024-2025</option>
                                <option value="2025-2026">2025-2026</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-end mb-5">
            <button type="submit" class="btn btn-purple btn-lg rounded-pill px-5 shadow fw-bold">
                <span class="material-symbols-outlined align-middle me-1">save</span> Preserve Changes
            </button>
        </div>
    </form>
}
else
{
    <div class="card border-0 shadow-sm bg-light p-5 text-center rounded-4">
        <span class="material-symbols-outlined display-1 mb-3 text-muted">domain_disabled</span>
        <h2 class="fw-bold">No Active Configuration</h2>
        <p class="lead mb-4">You need to select a company or register a new business profile to manage global settings.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-action="List" class="btn btn-light rounded-pill px-4 border">View Entities</a>
            <a asp-action="Index" asp-route-id="0" class="btn btn-purple rounded-pill px-4 shadow">Add New Business</a>
        </div>
    </div>
}

<style>
    .ls-1 { letter-spacing: 0.1em; }
    .x-small { font-size: 0.75rem; }
    .cursor-pointer { cursor: pointer; }
</style>
