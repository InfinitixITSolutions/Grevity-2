@model Grevity.Models.ViewModels.ForgotPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="text-center mb-4">
    <span class="material-symbols-outlined text-primary mb-2" style="font-size: 3rem">lock_reset</span>
    <h3 class="fw-bold">Forgot Password?</h3>
    <p class="text-muted small">Enter your email address to receive a One-Time Password (OTP).</p>
</div>

<form asp-action="ForgotPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    
    <div class="mb-4">
        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    
    <div class="d-grid mb-4">
        <button type="submit" class="btn btn-primary btn-lg shadow-sm">Send OTP</button>
    </div>

    <div class="text-center">
        <a asp-action="Login" class="text-primary fw-bold text-decoration-none small">&larr; Back to Login</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
