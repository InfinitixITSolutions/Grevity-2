@model Grevity.Models.ViewModels.ResetPasswordViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="text-center mb-4">
    <span class="material-symbols-outlined text-primary mb-2" style="font-size: 3rem">lock_open</span>
    <h3 class="fw-bold">Reset Password</h3>
    <p class="text-muted small">Choose a strong password to secure your account.</p>
</div>

<form asp-action="ResetPassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Otp" />
    
    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
        <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>
    
    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>
    
    <div class="d-grid mb-3">
        <button type="submit" class="btn btn-primary btn-lg shadow-sm">Reset Password</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
