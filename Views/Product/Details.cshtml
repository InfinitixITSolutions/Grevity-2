@model Grevity.Models.Entities.Product

@{
    ViewData["Title"] = "Product: " + Model.Name;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Catalog</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
        <h2 class="h3 mb-0 fw-bold">Inventory Intelligence</h2>
    </div>
    <div class="col-md-6 text-md-end">
        <div class="d-flex gap-2 justify-content-md-end">
            <a asp-action="Index" class="btn btn-light rounded-pill px-3">
                <span class="material-symbols-outlined align-middle me-1">arrow_back</span> Catalog
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-purple rounded-pill px-4 shadow-sm">
                <span class="material-symbols-outlined align-middle me-1">edit_square</span> Edit Item
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
            <div class="p-5 bg-purple-light text-center">
                <div class="rounded-4 bg-white shadow-sm d-inline-block p-4 mb-3">
                    <span class="material-symbols-outlined text-primary" style="font-size: 4rem">inventory_2</span>
                </div>
                <h4 class="fw-bold mb-1">@Model.Name</h4>
                <div class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill x-small text-uppercase ls-1">@Model.ItemType Item</div>
            </div>
            <div class="card-body p-4 text-center">
                <p class="text-muted small mb-0">@Model.Description</p>
            </div>
            <div class="card-footer bg-white border-0 p-4 text-center border-top">
                <div class="text-muted x-small text-uppercase ls-1 mb-1">HSN/SAC Code</div>
                <div class="h5 fw-bold text-dark">@Model.HSN</div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <div class="d-flex align-items-center mb-4">
                <span class="material-symbols-outlined text-primary me-2">payments</span>
                <h5 class="mb-0 fw-bold">Commercials</h5>
            </div>
            
            <div class="row g-4">
                <div class="col-sm-6">
                    <div class="p-4 rounded-4 bg-light border-start border-primary border-4">
                        <div class="text-muted x-small text-uppercase ls-1 mb-1">Selling Price</div>
                        <div class="h3 fw-bold text-primary mb-0">@(Model.Price?.ToString("C") ?? "N/A")</div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="p-4 rounded-4 bg-light border-start border-warning border-4">
                        <div class="text-muted x-small text-uppercase ls-1 mb-1">Purchase Cost</div>
                        <div class="h3 fw-bold text-warning mb-0">@(Model.PurchasePrice?.ToString("C") ?? "N/A")</div>
                    </div>
                </div>
                @if (ViewBag.IsGSTEnabled != false)
                {
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center p-3 rounded-4 border">
                            <span class="material-symbols-outlined text-muted me-3" style="font-size: 2rem">percent</span>
                            <div>
                                <div class="text-muted x-small text-uppercase ls-1">Tax Slab</div>
                                <div class="fw-bold">@(Model.GSTPercentage?.ToString() ?? "0")% GST</div>
                            </div>
                        </div>
                    </div>
                }
                <div class="col-sm-6">
                    <div class="d-flex align-items-center p-3 rounded-4 border">
                        <span class="material-symbols-outlined text-muted me-3" style="font-size: 2rem">straighten</span>
                        <div>
                            <div class="text-muted x-small text-uppercase ls-1">Measurement Unit</div>
                            <div class="fw-bold">@Model.Unit</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center mb-4">
                <span class="material-symbols-outlined text-primary me-2">analytics</span>
                <h5 class="mb-0 fw-bold">Stock Insights</h5>
            </div>
            <div class="p-5 text-center bg-light rounded-4">
                <span class="material-symbols-outlined display-4 text-muted mb-2">query_stats</span>
                <p class="text-muted mb-0">Transaction analytics will be available once the ledger is processed.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .ls-1 { letter-spacing: 0.1em; }
    .x-small { font-size: 0.75rem; }
    .bg-purple-light { background-color: var(--md-primary-light); }
</style>
